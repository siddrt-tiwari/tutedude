.venv
.env

# Local .terraform directories (contains provider binaries and plugins)
**/.terraform/*

# .tfstate files (contains plain-text secrets and state history)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (likely to contain sensitive data like passwords/keys)
*.tfvars
*.tfvars.json

# Ignore override files (used to temporarily modify resources locally)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created during terraform apply
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan outputs (optional, best practice if you save plans locally)
*tfplan*